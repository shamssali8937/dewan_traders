// This is your Prisma schema file for Dewan Traders Management System
// Sargodha-based import/export company: Fruits, Vegetables, Surgical, Sports Items

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  admin
  manager
  individual
  company
}

enum UserType {
  individual
  company
}

enum ProductCategory {
  fruits
  vegetables
  rice
  surgical
  sports
}

enum InquiryStatus {
  pending
  read
  responded
  closed
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
}

enum PaymentStatus {
  pending
  paid
  partial
  refunded
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  phone        String?
  role         Role     @default(individual)
  userType     UserType @default(individual)
  isActive     Boolean  @default(true)
  refreshToken String?

  // Company-specific fields
  companyName   String?
  companyReg    String?
  taxNumber     String?
  businessType  String?
  address       String?
  city          String?
  country       String?  @default("Pakistan")
  postalCode    String?
  website       String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders    Order[]
  inquiries Inquiry[]

  @@map("users")
}

// ─────────────────────────────────────────
// PRODUCTS & CATEGORIES
// ─────────────────────────────────────────

model Category {
  id          String          @id @default(cuid())
  name        String          @unique
  slug        String          @unique
  type        ProductCategory
  description String?
  imageUrl    String?
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  sku         String   @unique
  description String?
  details     String?
  price       Decimal  @db.Decimal(10, 2)
  minOrderQty Int      @default(1)
  unit        String   @default("kg") // kg, piece, box, carton
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  imageUrl    String?
  images      String[] @default([])
  origin      String?  // Country of origin

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

// ─────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  status          OrderStatus   @default(pending)
  paymentStatus   PaymentStatus @default(pending)
  subtotal        Decimal       @db.Decimal(12, 2)
  tax             Decimal       @default(0) @db.Decimal(10, 2)
  shippingCost    Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(12, 2)
  notes           String?
  shippingAddress String?
  billingAddress  String?
  trackingNumber  String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(12, 2)
  notes     String?

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@map("order_items")
}

// ─────────────────────────────────────────
// INQUIRIES
// ─────────────────────────────────────────

model Inquiry {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  subject     String
  message     String
  productName String?
  status      InquiryStatus @default(pending)
  adminNotes  String?
  respondedAt DateTime?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inquiries")
}

// ─────────────────────────────────────────
// JOURNAL / BLOG
// ─────────────────────────────────────────

model JournalPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  imageUrl    String?
  tags        String[] @default([])
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  author      String   @default("Dewan Traders")
  readTime    Int?     // minutes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("journal_posts")
}

// ─────────────────────────────────────────
// PAGE CONTENT (CMS)
// ─────────────────────────────────────────

model PageContent {
  id       String @id @default(cuid())
  page     String @unique // home, about, services, industries, contact
  title    String?
  subtitle String?
  content  Json   @default("{}")  // Flexible JSON for different page sections
  metaTitle String?
  metaDescription String?
  isPublished Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("page_contents")
}

// ─────────────────────────────────────────
// CONTACT INFO
// ─────────────────────────────────────────

model ContactInfo {
  id        String @id @default(cuid())
  address   String?
  city      String?
  country   String?
  phone1    String?
  phone2    String?
  email1    String?
  email2    String?
  facebook  String?
  twitter   String?
  linkedin  String?
  instagram String?
  whatsapp  String?
  mapEmbed  String?
  workingHours String?

  updatedAt DateTime @updatedAt

  @@map("contact_info")
}

// ─────────────────────────────────────────
// TESTIMONIALS
// ─────────────────────────────────────────

model Testimonial {
  id        String  @id @default(cuid())
  name      String
  position  String?
  company   String?
  message   String
  rating    Int     @default(5)
  imageUrl  String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())

  @@map("testimonials")
}
